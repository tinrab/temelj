{
  "name": "@temelj/mdx",
  "version": "0.12.0",
  "description": "MDX processing utilities.",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/tinrab/temelj"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/mod.mjs",
  "types": "./dist/mod.d.mts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.mts",
      "import": "./dist/mod.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "shx rm -rf dist"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@shikijs/transformers": "^4.2.0",
    "@standard-schema/spec": "^1.1.0",
    "@temelj/iterator": "workspace:*",
    "@temelj/standard-schema": "workspace:*",
    "@types/hast": "^3.0.4",
    "github-slugger": "^2.0.0",
    "hast": "^1.0.0",
    "hast-util-to-string": "^3.0.1",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^4.2.0",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3",
    "vfile-matter": "^5.0.1"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "25.9.2",
    "shx": "^0.4.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
